		"lucide-svelte": "^1.0.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.4"
	},
